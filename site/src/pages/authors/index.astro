---
// site/src/pages/authors/index.astro
import { getCollection } from 'astro:content';
// 1. LINK THE SHARED VARIABLES AND BASE DOCUMENT STYLES
import '../../styles/global.css';

const allPosts = await getCollection('blog');

const authorCounts: Record<string, number> = {};
allPosts.forEach(post => {
  const author = post.data.author || 'system';
  const cleanAuthor = author.trim();
  if (cleanAuthor) {
    authorCounts[cleanAuthor] = (authorCounts[cleanAuthor] || 0) + 1;
  }
});

const sortedAuthors = Object.keys(authorCounts).sort();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Authors Register — Latent Verse</title>
</head>
<body>
<header>
    <span class="site-title"><a href="/">LATENT VERSE</a></span>
    <div class="internal-links">
      <a href="/">[ root_feed ]</a>
      <a href="/blog">[ archive_ledger ]</a>
      <a href="/tags">[ tags_index ]</a>
      <a href="/authors">[ authors_index ]</a>
      <a href="/about">[ about_manifesto ]</a>
      <a href="/search">[ search_blog ]</a>
    </div>
  </header>

  <main>
    <h2 class="section-heading">Operator Registry</h2>
    <div class="grid">
      {sortedAuthors.map(author => (
        <a href={`/authors/${author.toLowerCase()}`} class="author-card">
          <span class="author-name">operator: {author}</span>
          <span class="author-count">[{authorCounts[author]} entries]</span>
        </a>
      ))}
    </div>
  </main>
</body>
</html>

<style>
  /* Local grid structures scoped exclusively to the Operators view */
  .section-heading {
    font-size: 1.25rem;
    border-left: 3px solid var(--accent-color);
    padding-left: 10px;
    margin-bottom: 24px;
    text-transform: uppercase;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px;
  }
  .author-card {
    background: rgba(255, 255, 255, 0.02);
    border: 2px solid var(--border-color);
    padding: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }
  :global(.dark) .author-card {
    background: #111111;
  }
  .author-card:hover { 
    background: var(--text-color);
  }
  .author-card:hover .author-name { color: var(--bg-color); }
  .author-card:hover .author-count { color: var(--bg-color); }
  .author-name { color: var(--text-color); font-weight: 700; }
  .author-count { color: var(--text-muted); font-size: 0.85rem; }
</style>