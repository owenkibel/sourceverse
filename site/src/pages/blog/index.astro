---
// site/src/pages/blog/index.astro

// Step out to pages -> src -> then down into content/blog via symlink
const matches = import.meta.glob('../../content/blog/*.md', { eager: true });
const allPosts = Object.values(matches);

// Chronological sort
const sortedPosts = allPosts.sort((a, b) => {
  const dateA = a.frontmatter.date ? Date.parse(a.frontmatter.date) : 0;
  const dateB = b.frontmatter.date ? Date.parse(b.frontmatter.date) : 0;
  
  const validA = isNaN(dateA) ? 0 : dateA;
  const validB = isNaN(dateB) ? 0 : dateB;

  return validB - validA;
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sourceverse Archive — Historical Ledger</title>
  <style>
    :root {
      --bg-primary: #0a0a0c;
      --bg-surface: #121215;
      --border-color: #222227;
      --text-main: #e2e2e9;
      --text-muted: #646470;
      --accent-green: #39ff14;
    }
    body {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      max-width: 900px;
      margin: 40px auto;
      padding: 0 24px;
      background: var(--bg-primary);
      color: var(--text-main);
      line-height: 1.6;
    }
    header {
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 24px;
      margin-bottom: 40px;
    }
    h1 { font-size: 1.75rem; margin: 0; font-weight: 700; color: #fff; }
    nav { margin-top: 12px; }
    nav a { color: var(--text-muted); text-decoration: none; margin-right: 20px; font-size: 0.9rem; }
    nav a.active { color: var(--accent-green); font-weight: bold; }
    nav a:hover { text-decoration: underline; }
    .archive-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 0;
      border-bottom: 1px solid var(--border-color);
    }
    .archive-row:hover { background: #111116; }
    .link-wrapper { flex-grow: 1; padding-right: 20px; }
    .archive-link { color: #fff; text-decoration: none; font-size: 1.1rem; }
    .archive-link:hover { color: var(--accent-green); }
    .stamp { font-size: 0.85rem; color: var(--text-muted); min-width: 100px; text-align: right; }
    .meta-tag { font-size: 0.75rem; color: #55556f; margin-right: 10px; }
  </style>
</head>
<body>
  <header>
    <h1>ARCHIVE LEDGER</h1>
    <nav>
      <a href="/">[ root_feed ]</a>
      <a href="/blog" class="active">[ archive_ledger ]</a>
    </nav>
  </header>

  <main>
    {sortedPosts.length === 0 ? (
      <p style="color: var(--text-muted);">// Archive manifest is currently clear.</p>
    ) : (
      sortedPosts.map((post) => {
        const title = post.frontmatter.title || "Unindexed Node";
        const displayDate = post.frontmatter.date 
          ? new Date(post.frontmatter.date).toISOString().split('T')[0]
          : "0000-00-00";

const extractedSlug = post.file ? post.file.split('/').pop().replace('.md', '') : '';
        
        // ADD .toLowerCase() HERE to safely match Astro's route ledger
        const derivedUrl = `/blog/${extractedSlug}`.toLowerCase();

        return (
          <div class="archive-row">
            <div class="link-wrapper">
              <span class="meta-tag">[{post.frontmatter.source || "raw"}]</span>
              <a href={derivedUrl} class="archive-link">{title}</a>
            </div>
            <div class="stamp">
              <span>{displayDate}</span>
            </div>
          </div>
        );
      })
    )}
  </main>
</body>
</html>