---
// site/src/pages/about.astro
import AboutContent, { frontmatter } from './_about-text.md';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{frontmatter.title} — Latent Verse</title>
  <style>
    :root {
      --bg-primary: #0a0a0c;
      --bg-surface: #121215;
      --border-color: #222227;
      --text-main: #e2e2e9;
      --text-muted: #787885;
      --accent-cyan: #00f0ff;
    }
    body {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      max-width: 900px;
      margin: 40px auto;
      padding: 0 24px;
      background: var(--bg-primary);
      color: var(--text-main);
      line-height: 1.6;
    }
    header {
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 24px;
      margin-bottom: 40px;
    }
    h1 { font-size: 1.75rem; margin: 0; font-weight: 700; color: #fff; letter-spacing: -0.05em; text-transform: uppercase; }
    nav { margin-top: 12px; }
    nav a { color: var(--accent-cyan); text-decoration: none; margin-right: 20px; font-size: 0.9rem; }
    nav a:hover { text-decoration: underline; }
    
    .manifesto-container {
      background: var(--bg-surface);
      padding: 32px;
      border-radius: 8px;
      border: 1px solid var(--border-color);
    }
    .manifesto-title { margin: 0 0 12px 0; font-size: 1.5rem; font-weight: 700; color: #fff; }
    
    .meta-strip {
      font-size: 0.8rem;
      color: var(--text-muted);
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 16px;
      margin-bottom: 24px;
    }
    .badge {
      background: #1a1a24;
      color: var(--accent-cyan);
      padding: 2px 8px;
      border-radius: 4px;
      font-size: 0.75rem;
      border: 1px solid #222235;
    }
    
    /* Scoped typography handling for the compiled Markdown elements */
    .markdown-content p {
      margin-bottom: 20px;
      text-align: justify;
    }
    .markdown-content p:last-child {
      margin-bottom: 0;
    }
    .markdown-content a {
      color: var(--accent-cyan);
      text-decoration: none;
    }
    .markdown-content a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <header>
    <h1>Latent Verse</h1>
    <nav>
      <a href="/">[ root_feed ]</a>
      <a href="/blog">[ archive_ledger ]</a>
      <a href="/tags">[ tags_index ]</a>
      <a href="/authors">[ authors_index ]</a>
      <a href="/about">[ about_manifesto ]</a>
    </nav>
  </header>

  <main>
    <div class="manifesto-container">
      <h2 class="manifesto-title">{frontmatter.title}</h2>
      
      <div class="meta-strip">
        <span>[{frontmatter.pubDate}]</span>
        <span>•</span>
        <span>operator: {frontmatter.author}</span>
        <span class="badge">src:{frontmatter.source}</span>
        <span class="badge">domain:{frontmatter.domain}</span>
      </div>

      <div class="markdown-content">
        <AboutContent />
      </div>
    </div>
  </main>
</body>
</html>