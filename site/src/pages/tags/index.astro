---
// site/src/pages/tags/index.astro
import { getCollection } from 'astro:content';
// 1. LINK THE SHARED VARIABLES AND BASE DOCUMENT STYLES
import '../../styles/global.css';

const allPosts = await getCollection('blog');

const tagCounts: Record<string, number> = {};
allPosts.forEach(post => {
  const tags = post.data.tags || [];
  const normalizedTags = Array.isArray(tags) ? tags : [tags];
  normalizedTags.forEach(tag => {
    const cleanTag = tag.trim();
    if (cleanTag) {
      tagCounts[cleanTag] = (tagCounts[cleanTag] || 0) + 1;
    }
  });
});

const sortedTags = Object.keys(tagCounts).sort();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tags Register — Latent Verse</title>
</head>
<body>
<header>
    <span class="site-title"><a href="/">LATENT VERSE</a></span>
    <div class="internal-links">
      <a href="/">[ root_feed ]</a>
      <a href="/blog">[ archive_ledger ]</a>
      <a href="/tags">[ tags_index ]</a>
      <a href="/authors">[ authors_index ]</a>
      <a href="/about">[ about_manifesto ]</a>
      <a href="/search">[ search_blog ]</a>
    </div>
  </header>

  <main>
    <h2 class="section-heading">System Tags Register</h2>
    <div class="grid">
      {sortedTags.map(tag => (
        <a href={`/tags/${tag.toLowerCase()}`} class="tag-card">
          <span class="tag-name">#{tag}</span>
          <span class="tag-count">[{tagCounts[tag]} units]</span>
        </a>
      ))}
    </div>
  </main>
</body>
</html>

<style>
  /* Local grid structures scoped exclusively to the Tags view */
  .section-heading {
    font-size: 1.25rem;
    border-left: 3px solid var(--accent-color);
    padding-left: 10px;
    margin-bottom: 24px;
    text-transform: uppercase;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
  }
  .tag-card {
    background: rgba(255, 255, 255, 0.02);
    border: 2px solid var(--border-color);
    padding: 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
  }
  :global(.dark) .tag-card {
    background: #111111;
  }
  .tag-card:hover { 
    background: var(--text-color);
  }
  .tag-card:hover .tag-name { color: var(--bg-color); }
  .tag-card:hover .tag-count { color: var(--bg-color); }
  .tag-name { color: var(--text-color); font-weight: 700; text-transform: lowercase; }
  .tag-count { color: var(--text-muted); font-size: 0.85rem; }
</style>