---
// site/src/pages/index.astro
import { getCollection } from 'astro:content';
// 1. LINK THE SHARED VARIABLES AND BASE DOCUMENT STYLES
import '../styles/global.css';

const allPosts = await getCollection('blog');

// Unified reverse-chronological sort
const sortedPosts = allPosts.sort((a, b) => {
  const dateA = a.data.date || a.data.pubDate ? Date.parse(a.data.date || a.data.pubDate) : 0;
  const dateB = b.data.date || b.data.pubDate ? Date.parse(b.data.date || b.data.pubDate) : 0;
  
  const validA = isNaN(dateA) ? 0 : dateA;
  const validB = isNaN(dateB) ? 0 : dateB;

  return validB - validA;
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Latent Verse Ledger</title>
</head>
<body>
<header>
    <span class="site-title"><a href="/">LATENT VERSE</a></span>
    <div class="internal-links">
      <a href="/">[ root_feed ]</a>
      <a href="/blog">[ archive_ledger ]</a>
      <a href="/tags">[ tags_index ]</a>
      <a href="/authors">[ authors_index ]</a>
      <a href="/about">[ about_manifesto ]</a>
      <a href="/search">[ search_blog ]</a>
    </div>
  </header>

  <main>
    {sortedPosts.length === 0 ? (
      <p style="color: var(--text-muted);">// No active markdown transmutations detected in target ledger.</p>
    ) : (
      sortedPosts.map((post) => {
        const fallbackTitle = post.data.title || "Untitled Fragment";
        const rawDate = post.data.date || post.data.pubDate;
        const displayDate = rawDate ? new Date(rawDate).toISOString().split('T')[0] : "0000-00-00";
        
        // Lowercased ID routing matches case-sensitive production environments cleanly
        const derivedUrl = `/blog/${post.id.toLowerCase()}`;

        const rawTags = post.data.tags || [];
        const normalizedTags = Array.isArray(rawTags) ? rawTags : [rawTags];

        return (
          <div class="post-card">
            <h2 class="post-title">
              <a href={derivedUrl}>{fallbackTitle}</a>
            </h2>
            <div class="meta-strip">
              <span>[{displayDate}]</span>
              <span>•</span>
              <span>operator: {post.data.author || "system"}</span>
              
              {post.data.source && (
                <span class="badge">src:{post.data.source}</span>
              )}
              {post.data.domain && (
                <span class="badge">domain:{post.data.domain}</span>
              )}
              {normalizedTags.map((tag) => (
                <span class="badge">#{tag}</span>
              ))}
            </div>
          </div>
        );
      })
    )}
  </main>
</body>
</html>

<style>
  /* Local layout components scoped exclusively to this document */
  .post-card {
    background: rgba(255, 255, 255, 0.02);
    padding: 24px;
    margin-bottom: 24px;
    border: 2px solid var(--border-color);
  }
  :global(.dark) .post-card {
    background: #111111;
  }
  .post-title { 
    margin: 0 0 10px 0; 
    font-size: 1.25rem; 
    font-weight: 700;
  }
  .post-title a { 
    border-bottom: none !important; 
  }
  .meta-strip {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.8rem;
    color: var(--text-muted);
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }
  .badge {
    background: rgba(0, 68, 136, 0.05);
    color: var(--text-color);
    padding: 2px 8px;
    font-size: 0.75rem;
    border: 1px solid var(--border-color);
    text-transform: lowercase;
  }
</style>