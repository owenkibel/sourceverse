---
// src/pages/tags/[tag].astro
export async function getStaticPaths() {
  // Fetch all markdown posts across your folder
  const allPosts = await Astro.glob('../../posts/*.md');
  
  // Extract a unique list of all tags generated by your scripts
  const uniqueTags = [...new Set(allPosts.map((post) => post.frontmatter.tags).flat().filter(Boolean))];

  // Return a path parameter list for Astro to compile at build time
  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) => post.frontmatter.tags?.includes(tag));
    return {
      params: { tag: tag.toLowerCase() },
      props: { posts: filteredPosts, tagName: tag },
    };
  });
}

const { tag } = Astro.params;
const { posts, tagName } = Astro.props;
---
<h1>Posts tagged with "{tagName}"</h1>
<ul>
  {posts.map((post) => <li><a href={post.url}>{post.frontmatter.title}</a></li>)}
</ul>